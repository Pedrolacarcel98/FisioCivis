{
  "name": "fisiocivis-local",
  "version": "1.0.0",
  "description": "Fisiocivis - Fisioterapia a Domicilio Sevilla",
  "main": "index.html",
  "scripts": {
    "dev": "concurrently \"npm run tailwind:watch\" \"browser-sync start --config bs-config.js\"",
    "tailwind:watch": "npx tailwindcss -i ./src/input.css -o ./css/tailwind.css --watch",
    "build": "npx tailwindcss -i ./src/input.css -o ./css/tailwind.css --minify",
    "serve": "browser-sync start --config bs-config.js"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "browser-sync": "^2.29.3",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2"
  }
}
